---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro";
import HeaderMobile from "@components/HeaderMobile.astro";
---

<Layout title="Chet Home">

  <Header/>
  <HeaderMobile/>

  <Container>
<div class="JoContain">
    <div class="JoBlog">
        <h1><img src="/images/jobloglogo.webp" alt="Jo's Blog'"/></h1>
        <h2>Welcome to Jo's Blog!</h2>
        <p>[blog bio]</p>
    </div>


</div> 
</Container>

<style>
    body{
        background-image: url("/images/JoStar.webp");
        background-repeat: repeat;
        background-color: rgb(40, 0, 53);
    }

    .JoContain{
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: rgb(0, 0, 0, .2);
        margin-top: 60px;}

    .JoBlog{
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px;
        border: 15px solid #ff00b4;
        border-style: ridge;
        width: 100%;
    }
    .JoBlog img{
        width:400px;
    }

    h1, h2, h3, p{
        color: #ffade6;
        font-family: "Comic Sans MS", sans-serif;}
</style>
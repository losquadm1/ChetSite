---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro"
import HeaderMobile from "@components/HeaderMobile.astro";
import Picture from "@components/Picture.astro";
import HeadTitle from "@components/HeadTitle.astro";
---

<Layout title="Meet the Crew">

  <Header/>
  <HeaderMobile title="Meet the Crew"/>

  <Container>
    <div class="body">
    <HeadTitle title="Meet the Chet Crew"/>

    <h2>The Creators</h2>

    <div class="creators">
    <Picture
      name="Michael Losquadro"
      role="Director/Lead Designer"
      picture="/images/pictureplacehold.webp"/>

       <Picture
      name="Candice Leach"
      role="Writer/Lead uppeteer"
      picture="/images/pictureplacehold.webp"/>

        <Picture
      name="Mars McInerny"
      role="Audio Engineer/Jo"
      picture="/images/pictureplacehold.webp"/>

        <Picture
      name="Dom Cacchione"
      role="Todd"
      picture="/images/pictureplacehold.webp"/>
    </div>

    <h2>Key Crew Members</h2>
    <div class="keycrew">
        <Picture
      name="Corinne Stanton"
      role="#1 Slatest in America/Becky"
      picture="/images/pictureplacehold.webp"/>

        <Picture
      name="Declan Caulfield"
      role="Assistant Director"
      picture="/images/pictureplacehold.webp"/>

        <Picture
      name="Krystal McAdams"
      role="Social Media Manager"
      picture="/images/pictureplacehold.webp"/>
    </div>
    <h2>Production Assistants</h2>
    <div class="pa">
    <Picture
      name="PA Name"
      role="Production Assistant"
      picture="/images/pictureplacehold.webp"/>
    </div>
</Container>

<style>
  .body{
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    align-content: center;
    align-items: center;
  }
  .creators{
    display: grid;
    grid-template-columns: auto auto;
  }
  .creators > *,
  .keycrew > *,
  .pa > * {
    scroll-snap-align: start;
  }
  @media (max-width: 999px){
    .creators{
        grid-template-columns: unset;
        grid-auto-flow: column;
        grid-auto-columns: minmax(240px, 78vw);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        gap: 12px;
    }
    @media (max-width: 519px){
        .creators{
            grid-auto-columns: minmax(220px, 86vw);
        }
    }}

    .keycrew{
    display: grid;
    grid-template-columns: auto auto auto;
  }
  @media (max-width: 768px){
    .keycrew{
          grid-template-columns: unset;
          grid-auto-flow: column;
          grid-auto-columns: minmax(240px, 78vw);
          overflow-x: auto;
          scroll-snap-type: x mandatory;
          gap: 12px;
    }
   
    }
     .pa{
    display: grid;
    grid-template-columns: auto auto auto auto;
  }
  @media (max-width: 999px){
    .pa{
      grid-template-columns: unset;
      grid-auto-flow: column;
      grid-auto-columns: minmax(240px, 78vw);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
    }
    @media (max-width: 519px){
        .pa{
        grid-auto-columns: minmax(220px, 86vw);
        }
    }}
  
</style>


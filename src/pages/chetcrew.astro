---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro"
import HeaderMobile from "@components/HeaderMobile.astro";
import Picture from "@components/Picture.astro";
import HeadTitleS from "@components/HeadTitleStick.astro";
---

<Layout title="Meet the Crew">
      <Header/>
      <HeaderMobile title="Meet the Crew"/>
          <HeadTitleS title="Meet the Chet Crew"/>
          
  <div class="page-snap">

    <section class="snap-panel" data-sticky-subtitle="The Creators">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Michael Losquadro"
              role="Director/Lead Designer"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Candice Leach"
              role="Writer/Lead Puppeteer"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="The Creators">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Mars McInerny"
              role="Audio Engineer/Jo"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Dom Cacchione"
              role="Todd"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Key Crew Members">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Corinne Stanton"
              role="#1 Slatest in America/Becky"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Declan Caulfield"
              role="Assistant Director"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Key Crew Members">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Krystal McAdams"
              role="Social Media Manager"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Demetria Boussios"
              role="Puppet Designer"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Production Assistants">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="PA Name"
              role="Production Assistant"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>
  </div>

<style>
  .page-snap {
    --crew-title-height: 60px;
    height: calc(100vh - var(--crew-title-height));
    height: calc(100dvh - var(--crew-title-height));
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .page-snap::-webkit-scrollbar {
    display: none;
  }

  .snap-panel {
    min-height: calc(100vh - var(--crew-title-height));
    min-height: calc(100dvh - var(--crew-title-height));
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }

  .intro-panel {
    justify-content: center;
    align-items: center;
  }

  .body{
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 12px;
  }

  .snap-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 40px;
    width: 100%;
    justify-items: center;
  }

  @media (max-width: 680px) {
    .page-snap {
      --crew-title-height: 64px;
    }

    .snap-section {
      grid-template-columns: 1fr;
    }
  }
</style>


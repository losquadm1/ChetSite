---
const { title } = Astro.props
import PauseButton from './PauseButton.astro';
---
<div class="headermobile">
    <div class="headermobile-bg" aria-hidden="true"></div>

    <nav>
        <h1 class="mobile-title">{title}</h1>
        <ul id="sidebar" class="sidebar">
            <div class="x">
                <PauseButton/>
                <button type="button" id="closeSidebar">
                    <p>✕</p>
                </button>
            </div>
            <li><a href="/">Home</a></li>
            
            <li>
                <span>Episodes</span>
                <ul>
                    <li><a href="/episodes/1-chet-goes-to-the-doctor">"Chet Goes to the Doctor"</a></li>
                    <li><a href="/episodes/2-chet-goes-to-a-party">"Chet Goes to a Party"</a></li>
                    <li><a href="/episodes/3-chet-falls-in-love">"Chet Falls in Love"</a></li>
                </ul>
            </li>
            
            <li>
                <span>Production</span>
                <ul>
                    <li><a href="/production/pre-production">"Pre-Production"</a></li>
                    <li><a href="/production/production">"Production"</a></li>
                    <li><a href="/production/post-production">"Post-Production"</a></li>
                </ul>
            </li>

            <li><a href="/jos-blog">Jo's Blog</a></li>

            <li class="pad"><a href="/chetcrew">Meet the Crew</a></li>
            
        </ul>

        <ul class="navbar">
            <li class="hideOnDesktop">
                <button type="button" id="menuToggle">
                    <span><img src="/images/navmobile.webp" alt="Menu"/></span>
                </button>
            </li>
        </ul>
    </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('sidebar')
    const toggle = document.getElementById('menuToggle')
    const closeBtn = document.getElementById('closeSidebar')

        if (!sidebar || !toggle || !closeBtn) return

    toggle.addEventListener('click', () => {
      sidebar.classList.add('open')
    })

    closeBtn.addEventListener('click', () => {
      sidebar.classList.remove('open')
    })

    // Close sidebar when clicking outside
    document.addEventListener('click', (e) => {
      if (e.target instanceof Node && !sidebar.contains(e.target) && !toggle.contains(e.target)) {
        sidebar.classList.remove('open')
      }
    })
  })
</script>

<style>
/* Close button container */
li{
    padding-top:20px;
}

.pad{
    padding-bottom:150px
}

.x {
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    gap: 0px;
    width: 100%;
    padding: 0 14px;
    margin-top: -5px;
}

.x > button,
.x :global(button.pause) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
}

/* Button styles */
button {
    background: none;
    border: none;
    cursor: pointer;
}

button:hover {
    color: red;
}

button p {
    font-size: 30px;
    line-height: 1;
    margin: 0;
}

/* Remove list styling */
ul {
    list-style-type: none;
}

/* Sidebar navigation */
.sidebar {
    position: fixed;
    z-index: 10000;
    top: 0;
    right: -250px;
    height: 100%;
    max-height: 100dvh;
    width: 250px;
    background-color: rgba(0, 0, 0);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    transition: right 0.3s ease;
    padding-top: 20px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
}

.sidebar.open {
    right: 0;
    width: 101%;
        margin-right: -4px;
    }
}

/* Sidebar list items */
.sidebar li {
    width: 100%;
    margin: 18px 0;
}

.sidebar > li:first-of-type {
    margin-top: 15px;
}

/* Sidebar links */
.sidebar a {
    color: white;
    text-decoration: none;
    padding: 5px 5px;
    display: block;
    width: 100%;
    font-weight: bold;
    font-size: 18px;
}

.sidebar a:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: #3DC6ED;
}

/* Episodes section title */
.sidebar span {
    color: white;
    padding: 5px 5px;
    display: block;
    width: 100%;
    font-weight: bold;
    font-size: 18px;
}

/* Nested episode links */
.sidebar ul ul {
    padding-left: 20px;
}

.sidebar ul ul li {
    margin: 5px 0;
}

.sidebar ul ul a {
    padding: 8px 5px;
    font-size: 14px;
}

/* Header container */
.headermobile {
    display: none;
    width: 100%;
    z-index: 1000;
    position: sticky;
    top: 0;
    min-height: 44px;
    padding: 0 15px;
    margin-top: -60px;
    box-sizing: border-box;
    
}

.headermobile-bg {
    position: absolute;
    top: -100vh;
    left: 0;
    right: 0;
    bottom: 0;
    height: calc(100% + 100vh);
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

nav {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.mobile-title {
    margin: 0;
    color: white;
    font-size: 1.1rem;
    line-height: 1.2;
    font-weight: 700;
    margin-left: 8px;
    margin-top: 25px;
    font-weight: 100;
}


@media (max-width: 700px) {
    .headermobile {
        display: flex;
    }
}
/* Navigation bar */
.navbar {    
    top: 0;
    padding-top: 10px;
    display: flex;
    align-items: center;
    position: relative;
    margin-right: 0;
    margin-left: auto;
}

/* Hamburger menu button */
.hideOnDesktop {
    display: flex;
}

.hideOnDesktop button {
    background: none;
    border: none;
    border-radius: 4px;
    padding: 6px;
    cursor: pointer;
    color: white;
    font-size: 18px;
    
    margin-top: 0;
    margin-right: -2px;

}

.hideOnDesktop button:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: #3DC6ED;
    color: #3DC6ED;
}

/* Mobile responsive adjustments */
@media (max-width: 700px) {
    .headermobile {
        padding: 0 15px;
    }
}

@media (max-width: 700px) {
    .sidebar {
        width: 100%;
        right: -100%; /* Start fully off-screen for 100% width */
    }

    .sidebar.open {
        right: 0; /* Slide in to fill the screen */
    }
}

.hideOnDesktop img{
    width: 30px;
}
ul{
    padding-left: 13px;
}

</style>
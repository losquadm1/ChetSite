<script>
  document.addEventListener("DOMContentLoaded", () => {
    const staticVideo = document.querySelector<HTMLVideoElement>(".tv-static-bg");
    const pauseBtn = document.querySelector<HTMLButtonElement>(".pause-static-btn");
    const scrollRoot = document.querySelector<HTMLElement>(".page-snap");
    const fadeItems = document.querySelectorAll(".page-snap .picture, .page-snap .everybody");

    if (staticVideo) {
      staticVideo.defaultMuted = true;
      staticVideo.muted = true;
      staticVideo.autoplay = true;
      staticVideo.playsInline = true;
      staticVideo.setAttribute("playsinline", "");
      staticVideo.setAttribute("webkit-playsinline", "");
      staticVideo.play().catch(() => {});
    }

    const scrollToHashTarget = (behavior: ScrollBehavior = "smooth") => {
      if (!scrollRoot || !window.location.hash) return;

      const target = document.querySelector<HTMLElement>(window.location.hash);
      if (!target) return;

      const offsetVar = getComputedStyle(scrollRoot).getPropertyValue("--crew-title-height").trim();
      const offset = Number.parseFloat(offsetVar) || 0;
      const relativeTop = target.getBoundingClientRect().top - scrollRoot.getBoundingClientRect().top;
      const top = Math.max(scrollRoot.scrollTop + relativeTop - offset, 0);

      scrollRoot.scrollTo({ top, behavior });
    };

    if (staticVideo && pauseBtn) {
      pauseBtn.addEventListener("click", () => {
        const shouldPause = !staticVideo.paused;

        if (shouldPause) {
          staticVideo.pause();
        } else {
          staticVideo.play().catch(() => {});
        }

        pauseBtn.setAttribute("aria-pressed", shouldPause ? "true" : "false");
        pauseBtn.textContent = shouldPause ? "Play Static" : "Pause Static";
      });
    }

    if (scrollRoot) {
      // Keep in-page anchors working when the page uses an internal scroll container.
      scrollToHashTarget("auto");
      requestAnimationFrame(() => scrollToHashTarget("auto"));
      setTimeout(() => scrollToHashTarget("auto"), 120);
      window.addEventListener("hashchange", () => scrollToHashTarget("smooth"));
    }

    if (!scrollRoot || !fadeItems.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting && entry.intersectionRatio >= 0.35);
        });
      },
      {
        root: scrollRoot,
        threshold: [0.15, 0.35, 0.6, 0.85],
      }
    );

    fadeItems.forEach((item) => observer.observe(item));
  });
</script>

<style>
.everybody{
  list-style: none;
  columns: 3;
  column-gap: 80px;
  margin: 0 auto;
  padding: 0;
  text-align: center;
  font-size: 24px;
  opacity: 0;
  transform: scale(0.985);
  transition: opacity 280ms ease, transform 280ms ease;
  will-change: opacity, transform;
}

.everybody li {
  white-space: nowrap;
}

  body{
    background-color: #010322;
  }

  .crew-shell {
    position: relative;
  }

  .tv-static-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    transform: scale(1.2);
    transform-origin: center;
    z-index: -1;
    pointer-events: none;
  }

  .pause-static-btn {
    position: absolute;
    left: 16px;
    bottom: 16px;
    z-index: 30;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 8px 12px;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
  }

  .pause-static-btn:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  :global(.page-snap .picture) {
    opacity: 0;
    transform: scale(0.985);
    transition: opacity 280ms ease, transform 280ms ease;
    will-change: opacity, transform;
  }

  :global(.page-snap .picture.is-visible) {
    opacity: 1;
    transform: scale(1);
  }

  .everybody.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.page-snap .picture),
    .everybody {
      transform: none;
      transition: none;
    }
  }

  .page-snap {
    --crew-title-height: 60px;
    position: relative;
    z-index: 1;
    height: 100vh;
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-top: var(--crew-title-height);
    box-sizing: border-box;
  }

  .page-snap::-webkit-scrollbar {
    display: none;
  }

  .snap-panel {
    min-height: calc(100vh - var(--crew-title-height));
    min-height: calc(100dvh - var(--crew-title-height));
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }

  #everybody {
    scroll-margin-top: var(--crew-title-height);
  }

  #everybody .snap-section {
    grid-template-columns: 1fr;
    width: 100%;
    justify-items: center;
    justify-content: center;
    gap: 0;
  }

  .intro-panel {
    justify-content: center;
    align-items: center;
  }

  .body{
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 12px;
    margin-top: 150px;
  }

  .snap-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 150px;
    margin-top: 15px;
    justify-items: center;
  }

  @media (max-width: 870px) {
    .everybody{
      columns: 2;
      margin-top: 100px;
      font-size: 18px;
      column-gap: 40px;
    }

    .page-snap {
      --crew-title-height: 64px;
      scroll-snap-type: y mandatory;
    }

    .snap-panel {
      min-height: calc(100svh - var(--crew-title-height));
      min-height: calc(100vh - var(--crew-title-height));
      min-height: calc(100dvh - var(--crew-title-height));
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    .body {
      margin-top: 0;
      width: 80vw;
      max-width: none;
    }

    .snap-section {
      grid-template-columns: 1fr;
      gap: 0;
      width: 100vw;
      max-width: none;
      justify-items: stretch;
      
    }

    .snap-section :global(.picture) {
      min-height: calc(100svh - var(--crew-title-height) - 24px);
      min-height: calc(100vh - var(--crew-title-height) - 24px);
      min-height: calc(100dvh - var(--crew-title-height) - 24px);
      scroll-snap-align: center;
      scroll-snap-stop: always;
      width: 100%;
      aspect-ratio: auto;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      margin-top: 0;
      margin-bottom: 0;
      padding: 0;
    }

    .snap-section :global(.picture img) {
      width: 400px;
      height: auto;

    margin-top:75px
    }
  }

  @media (max-height: 800px) {
    .snap-section :global(.picture img) {
      width: 120px;
      height: auto;
    }

    .snap-section {
      gap: 0px;
    }
  }

  @media (max-width: 600px) {
    .pause-static-btn {
      display: none;
    }
  }
@media (min-height: 1080px) {
    .snap-section {
      gap: 350px;
    }
    }

</style>


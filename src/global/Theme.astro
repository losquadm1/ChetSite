<style is:global>
  /* We can use this style tag to set up colors, fonts, etc. */
  :root {
    --color-background: rgb(0, 0, 0);
    --color-text: rgb(255, 255, 255);
    --color-accent: #3DC6ED;
    --color-focus-ring: rgb(255, 255, 255);

    --font-body: 'Times New Roman', Times, serif;
    --font-headings: 'Times New Roman', Times, serif; Weight: bold;

    font-size: 18px;

    /* These sizes are used by the Container component to set up the page container */
    --size-page-width: 1100px;
    --size-page-padding: 1rem;
  }

  /* We can also apply these colors as a default */
a{
  color: var(--color-accent);
}

a:hover{
  color: #8bd5f1;
}

a:visited{
  color: #34a6d9;
}

  body {
    background-color: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-body);
  }
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--color-text);
    font-family: var(--font-headings);
  }

  /* default focus ring styles */
  *:focus-visible {
    outline: 3px solid var(--color-focus-ring);
  }

  p {
    font-family: 'Times New Roman', Times, serif;
    color: var(--color-text);
  }

  h1{
    font-size: 60px;
    padding-bottom: 10px;
    text-align: center;
  }

  h2{
    font-size: 40px;
    padding-bottom: 10px;
  }

  h3{
    font-size: 30px;
    padding-bottom: 10px;
  }

  @media (max-width: 768px){
    h1{
      font-size: 40px;
    }
    h2{
      font-size: 30px;
    }
  }
</style>

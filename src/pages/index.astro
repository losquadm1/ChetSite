<script is:inline>
  const heroVideoLayer = document.querySelector(".hero-video-layer");
  const heroLogoLayer = document.querySelector(".hero-logo-layer");

  if (heroVideoLayer && heroLogoLayer) {
    let fadeDistance = 1;
    let scrollTicking = false;

    const updateFadeDistance = (force = false) => {
      const nextDistance = Math.max(window.innerHeight || 1, 1);

      // Mobile browser chrome can fire tiny resize events while scrolling.
      // Only accept large changes unless forced (e.g. initial load/orientation).
      if (force || Math.abs(nextDistance - fadeDistance) > 120) {
        fadeDistance = nextDistance;
      }
    };

    const setHeroOpacity = () => {
      const progress = Math.min(window.scrollY / fadeDistance, 1);
      const videoEffectProgress = Math.min(progress * 2, 1);
      const logoProgress = Math.min(progress * 3, 1);
      const videoBlurProgress = videoEffectProgress * 0.7;
      const maxVideoBlurPx = 10;

      heroVideoLayer.style.opacity = String(1 - 0.9 * videoEffectProgress);
      heroVideoLayer.style.filter = `blur(${maxVideoBlurPx * videoBlurProgress}px)`;
      heroLogoLayer.style.opacity = String(1 - logoProgress);
    };

    const onScroll = () => {
      if (scrollTicking) return;

      scrollTicking = true;
      window.requestAnimationFrame(() => {
        setHeroOpacity();
        scrollTicking = false;
      });
    };

    updateFadeDistance(true);
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      updateFadeDistance(false);
      setHeroOpacity();
    });
    window.addEventListener("orientationchange", () => {
      updateFadeDistance(true);
      setHeroOpacity();
    });
    setHeroOpacity();
  }
</script>

<style>

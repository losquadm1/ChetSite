---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro"
import HeaderMobile from "@components/HeaderMobile.astro";
import Picture from "@components/Picture.astro";
import HeadTitle from "@components/HeadTitle.astro";
---

<Layout title="Meet the Crew">
  <div class="page-snap">
    <section class="snap-panel intro-panel">
      <Header/>
      <HeaderMobile title="Meet the Crew"/>
      <Container>
        <div class="body">
          <HeadTitle title="Meet the Chet Crew"/>
        </div>
      </Container>
    </section>

    <section class="snap-panel">
      <Container>
        <div class="body">
          <h2>The Creators</h2>
          <section class="snap-section">
            <Picture
              name="Michael Losquadro"
              role="Director/Lead Designer"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Candice Leach"
              role="Writer/Lead Puppeteer"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel">
      <Container>
        <div class="body">
          <h2>The Creators</h2>
          <section class="snap-section">
            <Picture
              name="Mars McInerny"
              role="Audio Engineer/Jo"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Dom Cacchione"
              role="Todd"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel">
      <Container>
        <div class="body">
          <h2>Key Crew Members</h2>
          <section class="snap-section">
            <Picture
              name="Corinne Stanton"
              role="#1 Slatest in America/Becky"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Declan Caulfield"
              role="Assistant Director"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel">
      <Container>
        <div class="body">
          <h2>Key Crew Members</h2>
          <section class="snap-section">
            <Picture
              name="Krystal McAdams"
              role="Social Media Manager"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Krystal McAdams"
              role="Social Media Manager"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel">
      <Container>
        <div class="body">
          <h2>Production Assistants</h2>
          <section class="snap-section">
            <Picture
              name="PA Name"
              role="Production Assistant"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>
  </div>

<style>
  .page-snap {
    height: 100vh;
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .page-snap::-webkit-scrollbar {
    display: none;
  }

  .snap-panel {
    min-height: 100vh;
    min-height: 100dvh;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem 0;
    text-align: center;
  }

  .intro-panel {
    justify-content: center;
    align-items: center;
  }

  .body{
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 12px;
  }

  .snap-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    width: 100%;
    justify-items: center;
  }

  @media (max-width: 680px) {
    .snap-section {
      grid-template-columns: 1fr;
    }
  }
</style>


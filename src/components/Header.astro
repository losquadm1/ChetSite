<style>
    /* The dropdown container */
.dropdown {
    font-weight: bold;
    float: left;
    overflow: visible;
}

.dropdown-content {
    padding-left: 5px;
    padding-bottom: 5px;
}

/* Dropdown button */
.dropdown .dropbtn {
  border: none;
  color: rgb(255, 255, 255);
    padding: 14px 0px;
  background-color: inherit;
  font-family: inherit; /* Important for vertical align on mobile phones */
  margin: 0; /* Important for vertical align on mobile phones */
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-right: -3px;
}
f

/* Add a red background color to navbar links on hover */
.navbar a:hover, .dropdown:hover .dropbtn {
  color:#3DC6ED;
}

/* Dropdown button focus state */
.dropbtn:focus {
  outline: 2px solid white;
  outline-offset: 2px;
}

/* Dropdown content (hidden by default) */
.dropdown-content {
  display: none;
  position: absolute;
  background-color: #000000;
  min-width: 160px;
  z-index: 995;
}

/* Links inside the dropdown */
.dropdown-content a {
  float: none;
  color: black;
  padding: 12px 16px;
  text-decoration: none;
  display: block;
  text-align: left;
padding-top: 5px;
}


/* Add a grey background color to dropdown links on hover */
.dropdown-content a:hover {
  background-color: #313131;
}

/* Show the dropdown menu on hover */
.dropdown:hover .dropdown-content, .dropdown:focus-within .dropdown-content {
  display: block;
}


</style>

<style>

.parent{
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 900;
    transition: transform 0.3s ease-in-out;
    transform: translateY(-65px);
    width: 100%;
}
.parent::after {
    content: '';
    display: block;
    height: 30px;
    width: 100%;
}
.parent.hover-active{
   transform: translateY(0);
}
.parent:focus-within{
   transform: translateY(0);
}
.parent.hover-active .chethand{
    margin-top: 10px;
    margin-right: 5px;
}
.parent:focus-within .chethand{
    margin-top: 10px;
    margin-right: 5px;
}
.parent.hover-active .chetbody{
    margin-top: 50px;
}
.parent:focus-within .chetbody{
    margin-top: 50px;
}

.chetbody{
    display: flex;
    justify-content: flex-end;
    position: absolute;
    top: 0;
    right: 0;
    margin-top: -20px;
    z-index: 998;
    transition: margin 0.5s ease-in-out;
}

.chetbody, .chethand img{
    max-width:200px;
    transform: rotate(180deg);
}

.chethand{
    display: flex;
    justify-content: flex-end;
    position: absolute;
    top: 0;
    right: 0;
    margin-top: 4px;
    margin-right:10px;
    z-index: 999;
    transition: margin 0.2s ease-in-out;
}
</style>

<script>
  const hoverDelay = 1800;
  const parentElement = document.querySelector('.parent');
    let hoverTimeout: number | undefined;
  if (parentElement) {
    parentElement.addEventListener('mouseenter', () => {
      clearTimeout(hoverTimeout);
      parentElement.classList.add('hover-active');
    });
    parentElement.addEventListener('mouseleave', () => {
      hoverTimeout = window.setTimeout(() => {
        parentElement.classList.remove('hover-active');
      }, hoverDelay);
    });
    document.addEventListener('click', (event) => {
            if (!(event.target instanceof Node)) return;
      if (!parentElement.contains(event.target)) {
        clearTimeout(hoverTimeout);
        parentElement.classList.remove('hover-active');
      }
    });  }
</script>
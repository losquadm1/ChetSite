---
const {name}= Astro.props;
const {role}= Astro.props;
const {picture}= Astro.props;
---
<div class="picture">
    <img src={picture}/>

    <div class="name">
        <h3>{name}</h3>
    </div>

    <div class="role">
        <h4>{role}</h4>
    </div>
</div>

<style>
.picture {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
    margin-top: 50px;
    aspect-ratio: 3 / 4;
    flex-wrap: nowrap;
}
.picture img {
    width: min(100%, 400px);
    max-width: 100%;
    height: auto;
}
.name{
    font-size: 20px;
}
.role{
    font-size: 16px;
    margin-top: -5px;
}

.name h3,
.role h4 {
    font-family: "Courier New", monospace;
}


@media (max-height: 800px) {
    .picture img {
        width: min(100%, 300px);
        max-width: 90vw;
        height: auto;
    }
}

@media (min-height: 1080px) {
    .picture img {
    width: min(58vw, 820px);
        max-width: 100%;
        height: auto;
}
}


</style>
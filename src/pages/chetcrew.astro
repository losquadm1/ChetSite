---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro"
import HeaderMobile from "@components/HeaderMobile.astro";
import Picture from "@components/Picture.astro";
import HeadTitleS from "@components/HeadTitleStick.astro";
---

<Layout title="Meet the Crew">
  <div class="crew-shell">
      <Header/>
      <HeaderMobile title="Meet the Crew"/>
          <HeadTitleS title="Meet the Chet Crew"/>

  <video class="tv-static-bg" autoplay muted loop playsinline aria-hidden="true">
    <source src="/images/TVStatic.webm" type="video/webm" />
  </video>

  <button class="pause-static-btn" type="button" aria-pressed="false">
    Pause Static
  </button>
          
  <div class="page-snap">

    <section class="snap-panel" data-sticky-subtitle="The Creators">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Michael Losquadro"
              role="Director/Lead Designer"
              picture="/images/pictureplacehold.webp"/>

            <Picture
              name="Candice Leach"
              role="Writer/Lead Puppeteer"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Creative Leads">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Mars McInerny"
              role="Audio Engineer/Jo"
              picture="/images/crew/Mars.webp"/>

            <Picture
              name="Dom Cacchione"
              role="Todd"
              picture="/images/crew/Dom.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Key On-Set Crew Members">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Corinne Stanton"
              role="#1 Slatest in America/Becky"
              picture="/images/crew/Corrine.webp"/>

            <Picture
              name="Declan Caulfield"
              role="Assistant Director"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Key Off-Set Crew Members">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="Krystal McAdams"
              role="Social Media Manager"
              picture="/images/crew/Krys.webp"/>

            <Picture
              name="Demetria Boussios"
              role="Puppet Designer"
              picture="/images/crew/Meech.webp"/>
          </section>
        </div>
      </Container>
    </section>

    <section class="snap-panel" data-sticky-subtitle="Production Assistants">
      <Container>
        <div class="body">
          <section class="snap-section">
            <Picture
              name="PA Name"
              role="Production Assistant"
              picture="/images/pictureplacehold.webp"/>
          </section>
        </div>
      </Container>
    </section>
  </div>
  </div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const staticVideo = document.querySelector<HTMLVideoElement>(".tv-static-bg");
    const pauseBtn = document.querySelector<HTMLButtonElement>(".pause-static-btn");
    const scrollRoot = document.querySelector(".page-snap");
    const pictures = document.querySelectorAll(".page-snap .picture");

    if (staticVideo && pauseBtn) {
      pauseBtn.addEventListener("click", () => {
        const shouldPause = !staticVideo.paused;

        if (shouldPause) {
          staticVideo.pause();
        } else {
          staticVideo.play().catch(() => {});
        }

        pauseBtn.setAttribute("aria-pressed", shouldPause ? "true" : "false");
        pauseBtn.textContent = shouldPause ? "Play Static" : "Pause Static";
      });
    }

    if (!scrollRoot || !pictures.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting && entry.intersectionRatio >= 0.35);
        });
      },
      {
        root: scrollRoot,
        threshold: [0.15, 0.35, 0.6, 0.85],
      }
    );

    pictures.forEach((picture) => observer.observe(picture));
  });
</script>

<style>
  body{
    background-color: #010322;
  }

  .crew-shell {
    position: relative;
  }

  .tv-static-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.05;
    transform: scale(1.2);
    transform-origin: center;
    z-index: -1;
    pointer-events: none;
  }

  .pause-static-btn {
    position: absolute;
    left: 16px;
    bottom: 16px;
    z-index: 30;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: 8px 12px;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
  }

  .pause-static-btn:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  :global(.page-snap .picture) {
    opacity: 0;
    transform: scale(0.985);
    transition: opacity 280ms ease, transform 280ms ease;
    will-change: opacity, transform;
  }

  :global(.page-snap .picture.is-visible) {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.page-snap .picture) {
      transform: none;
      transition: none;
    }
  }

  .page-snap {
    --crew-title-height: 60px;
    position: relative;
    z-index: 1;
    height: 100vh;
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-top: var(--crew-title-height);
    box-sizing: border-box;
  }

  .page-snap::-webkit-scrollbar {
    display: none;
  }

  .snap-panel {
    min-height: calc(100vh - var(--crew-title-height));
    min-height: calc(100dvh - var(--crew-title-height));
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }

  .intro-panel {
    justify-content: center;
    align-items: center;
  }

  .body{
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 12px;
    margin-top: 150px;
  }

  .snap-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 150px;
    margin-top: 15px;
    justify-items: center;
  }

  @media (max-width: 870px) {
    .page-snap {
      --crew-title-height: 64px;
      scroll-snap-type: y mandatory;
    }

    .snap-panel {
      min-height: auto;
      scroll-snap-align: none;
      scroll-snap-stop: normal;
    }

    .body {
      margin-top: 0;
      width: 80vw;
      max-width: none;
    }

    .snap-section {
      grid-template-columns: 1fr;
      gap: 0;
      width: 100vw;
      max-width: none;
      justify-items: stretch;
      
    }

    .snap-section :global(.picture) {
      min-height: calc(100svh - var(--crew-title-height) - 24px);
      min-height: calc(100vh - var(--crew-title-height) - 24px);
      min-height: calc(100dvh - var(--crew-title-height) - 24px);
      scroll-snap-align: center;
      scroll-snap-stop: always;
      width: 100%;
      aspect-ratio: auto;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      margin-top: 0;
      margin-bottom: 0;
      padding: 0;
    }

    .snap-section :global(.picture img) {
      width: 400px;
      height: auto;

    margin-top:50px
    }
  }

  @media (max-height: 800px) {
    .snap-section :global(.picture img) {
      width: 120px;
      height: auto;
    }

    .snap-section {
      gap: 0px;
    }
  }

  @media (max-width: 600px) {
    .pause-static-btn {
      display: none;
    }
  }
@media (min-height: 1080px) {
    .snap-section {
      gap: 350px;
    }
    }

</style>


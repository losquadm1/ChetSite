<style>

    .title{
        display: flex;
        justify-content: center;
        padding-top: 60px;
    }

    .desc{        
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    justify-self: center;
    padding: 30px;
    padding-bottom: 50px;
    align-content: center;
}

    .creditg{
        padding: 20px
    }
    .credits{
        align-self: center;
        display: grid;
        flex-direction:column;
        justify-self: center;
        text-align: center;
        grid-template-columns: repeat(2, 1fr);
    }
    @media (max-width:722px){
        .credits{
            grid-template-columns: repeat(1, 1fr);
        }}
    .creditsi{
         align-self: center;
        display: flex;
        flex-direction:column;
        justify-self: center;
        text-align: center;
        padding: 10px
    }
    .episode{
        display: flex;
        flex-direction: column;
        place-self: center;
        place-content: center;
        flex-wrap: wrap;
    }

    .imdb{
        display: flex;
        justify-content: flex-start;
    }

    .imdb a img{
        max-width: 64px;
    }


    </style>

</div>

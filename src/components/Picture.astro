---
const {name}= Astro.props;
const {role}= Astro.props;
const {picture}= Astro.props;
---
<div class="picture">
    <img src={picture}/>

    <div class="name">
        <h3>{name}</h3>
    </div>

    <div class="role">
        <h4>{role}</h4>
    </div>
</div>

<style>
.picture {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20px;
    margin-top: 50px;
    aspect-ratio: 3 / 4;
    flex-wrap: nowrap;
}
.picture img {
    width:600px
}
.name{
    font-size: 20px;
}
.role{
    font-size: 16px;
    margin-top: -5px;
}


@media (max-height: 1100px) {
    .picture img {
        width: 300px !important;
        max-width: 90vw;
        height: auto;
    }
}


}
</style>
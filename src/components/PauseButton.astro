---

---
<div class="pause-button">
    <button class="pause">
        <div class="symbol-play">
            <img src="/images/play.svg" alt="play">
        </div>
        <div class="symbol-pause">
            <img src="/images/pause.svg" alt="pause">
        </div>
    </button>
</div>

<style>
    .symbol-play,
    .symbol-pause {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    margin-left:-30px
    }

    .symbol-hidden {
        opacity: 0;
    }

    .pause-button {
        display: flex;
    }

    .pause-button:hover {
        -webkit-filter: brightness(60%);
        filter: brightness(60%);
    }

    button.pause {
        all: unset;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        cursor: pointer;
    }

    img {
        width: 22.87px;
        display: block;
    }
    @media (max-width: 800px) {
        .symbol-play,
    .symbol-pause  {
            margin-left: -30px;
            margin-top: 0px;
        }
    }
</style>

<script>
    const STORAGE_KEY = 'site-paused';
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const stored = localStorage.getItem(STORAGE_KEY);
    // If no saved preference, default to paused when reduced motion is on
    let isPaused = stored !== null ? stored === '1' : prefersReducedMotion;

    // Block autoplay while paused
    document.addEventListener('play', (e) => {
        const target = e.target;
        if (isPaused && target instanceof HTMLVideoElement) {
            target.pause();
        }
    }, true);

    function applyState(paused: boolean) {
        isPaused = paused;
        document.querySelectorAll('.symbol-play').forEach(el => el.classList.toggle('symbol-hidden', paused));
        document.querySelectorAll('.symbol-pause').forEach(el => el.classList.toggle('symbol-hidden', !paused));
        document.querySelectorAll('video').forEach(v => paused ? v.pause() : v.play());
        localStorage.setItem(STORAGE_KEY, paused ? '1' : '0');
    }

    // Restore state on page load
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.symbol-play').forEach(el => el.classList.toggle('symbol-hidden', isPaused));
        document.querySelectorAll('.symbol-pause').forEach(el => el.classList.toggle('symbol-hidden', !isPaused));
        if (isPaused) {
            document.querySelectorAll('video').forEach(v => v.pause());
        }
    }, { once: true });

    document.querySelectorAll('button.pause').forEach(btn => {
        btn.addEventListener('click', () => applyState(!isPaused));
    });
</script>
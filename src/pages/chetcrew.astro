<script>
  document.addEventListener("DOMContentLoaded", () => {
    const staticVideo = document.querySelector<HTMLVideoElement>(".tv-static-bg");
    const scrollRoot = document.querySelector<HTMLElement>(".page-snap");
    const fadeItems = document.querySelectorAll(".page-snap .picture, .page-snap .everybody");
    const panels = document.querySelectorAll<HTMLElement>(".page-snap .snap-panel");
    const everybodyPanel = document.querySelector<HTMLElement>("#everybody");
    const crewFooter = document.querySelector<HTMLElement>(".crew-footer");

    if (staticVideo) {
      staticVideo.defaultMuted = true;
      staticVideo.muted = true;
      staticVideo.autoplay = true;
      staticVideo.playsInline = true;
      staticVideo.setAttribute("playsinline", "");
      staticVideo.setAttribute("webkit-playsinline", "");
      staticVideo.play().catch(() => {});
    }

    const scrollToHashTarget = (behavior: ScrollBehavior = "smooth") => {
      if (!scrollRoot || !window.location.hash) return;

      const target = document.querySelector<HTMLElement>(window.location.hash);
      if (!target) return;

      const offsetVar = getComputedStyle(scrollRoot).getPropertyValue("--crew-title-height").trim();
      const offset = Number.parseFloat(offsetVar) || 0;
      const relativeTop = target.getBoundingClientRect().top - scrollRoot.getBoundingClientRect().top;
      const top = Math.max(scrollRoot.scrollTop + relativeTop - offset, 0);

      scrollRoot.scrollTo({ top, behavior });
    };

    if (scrollRoot) {
      // Keep in-page anchors working when the page uses an internal scroll container.
      scrollToHashTarget("auto");
      requestAnimationFrame(() => scrollToHashTarget("auto"));
      setTimeout(() => scrollToHashTarget("auto"), 120);
      window.addEventListener("hashchange", () => scrollToHashTarget("smooth"));
    }

    if (scrollRoot && everybodyPanel && crewFooter && panels.length) {
      const panelRatios = new Map<HTMLElement, number>();

      panels.forEach((panel) => panelRatios.set(panel, 0));

      const panelObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            panelRatios.set(entry.target as HTMLElement, entry.intersectionRatio);
          });

          let activePanel: HTMLElement | null = null;
          let bestRatio = 0;

          panelRatios.forEach((ratio, panel) => {
            if (ratio > bestRatio) {
              bestRatio = ratio;
              activePanel = panel;
            }
          });

          const showFooter = activePanel === everybodyPanel && bestRatio >= 0.55;
          crewFooter.classList.toggle("is-visible", showFooter);
        },
        {
          root: scrollRoot,
          threshold: [0, 0.25, 0.5, 0.75, 1],
        }
      );

      panels.forEach((panel) => panelObserver.observe(panel));
    }

    if (!scrollRoot || !fadeItems.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting && entry.intersectionRatio >= 0.35);
        });
      },
      {
        root: scrollRoot,
        threshold: [0.15, 0.35, 0.6, 0.85],
      }
    );

    fadeItems.forEach((item) => observer.observe(item));
  });
</script>

<style>

.everybody{
  list-style: none;
  columns: 3;
  column-gap: 80px;
  margin: 0 auto;
  padding: 0;
  text-align: center;
  font-size: clamp(1rem, 2vw, 24px);
  opacity: 0;
  transform: scale(0.985);
  transition: opacity 280ms ease, transform 280ms ease;
  will-change: opacity, transform;
  padding-top: 0px;
  margin-top:-120px;
}

.everybody li {
  white-space: nowrap;
}

  body{
    background-color: #010322;
  }

  .crew-shell {
    position: relative;
  }

  .crew-footer {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 220ms ease, visibility 0s linear 220ms;
  }

  .crew-footer.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s;
  }

  .tv-static-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    transform: scale(1.2);
    transform-origin: center;
    z-index: -1;
    pointer-events: none;
  }

  :global(.page-snap .picture) {
    opacity: 0;
    transform: scale(0.985);
    transition: opacity 280ms ease, transform 280ms ease;
    will-change: opacity, transform;
  }

  :global(.page-snap .picture.is-visible) {
    opacity: 1;
    transform: scale(1);
  }

  .everybody.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.page-snap .picture),
    .everybody {
      transform: none;
      transition: none;
    }
  }

  .page-snap {
    --crew-title-height: 60px;
    --crew-footer-reserve: 96px;
    position: relative;
    z-index: 1;
    height: 100vh;
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-top: var(--crew-title-height);
    box-sizing: border-box;
  }

  .page-snap::-webkit-scrollbar {
    display: none;
  }

  .snap-panel {
    min-height: calc(100vh - var(--crew-title-height));
    min-height: calc(100dvh - var(--crew-title-height));
    max-height: 100vh;
    max-height: 100dvh;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    box-sizing: border-box;
    padding-bottom: var(--crew-footer-reserve);
  }

  #everybody {
    scroll-margin-top: var(--crew-title-height);
  }

  #everybody .snap-section {
    grid-template-columns: 1fr;
    width: 100%;
    justify-items: center;
    justify-content: center;
    gap: 0;
  }

  .intro-panel {
    justify-content: center;
    align-items: center;
  }

  .body{
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 12px;
    margin-top: 150px;
  }

  .snap-section {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 15vh;
    margin-top: 125px;
    justify-items: center;
    padding-top:100px;
  }

  @media (min-width: 871px) {
    .body {
      margin-top: clamp(20px, 4vh, 52px);
      width: min(1180px, 94vw);
      max-height: calc(100dvh - var(--crew-title-height) - var(--crew-footer-reserve));
      justify-content: center;
    }

    .snap-section {
      align-items: center;
      max-height: calc(100dvh - var(--crew-title-height) - var(--crew-footer-reserve));
    }

    .snap-section :global(.picture) {
      max-height: calc(100dvh - var(--crew-title-height) - var(--crew-footer-reserve));
      margin-top: -30px;
      margin-bottom: 0;
      justify-content: center;
    }

    .snap-section :global(.picture img) {
      width: clamp(160px, 22vw, 320px);
      max-height: calc(100dvh - var(--crew-title-height) - var(--crew-footer-reserve) - 120px);
      object-fit: contain;
    }
  }

  @media (max-width: 870px) {
    .everybody{
      columns: 2;
      margin-top: -10px;
      font-size: clamp(0.85rem, 2.6vw, 1rem);
      column-gap: 30px;
      padding-top: 30px;
    }

    .page-snap {
      --crew-title-height: 64px;
      --crew-footer-reserve: 0px;
      scroll-snap-type: y mandatory;
    }

    .snap-panel {
      min-height: auto;
      max-height: none;
      scroll-snap-align: none;
      scroll-snap-stop: normal;
      padding-bottom: 0;
    }

    #everybody.snap-panel {
      min-height: calc(100svh - var(--crew-title-height));
      min-height: calc(100vh - var(--crew-title-height));
      min-height: calc(100dvh - var(--crew-title-height));
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    .body {
      margin-top: clamp(8px, 2.2vh, 20px);
      width: 80vw;
      max-width: none;
    }

    .snap-section {
      grid-template-columns: 1fr;
      gap: 0;
      width: 100vw;
      max-width: none;
      justify-items: stretch;
      margin-top: 0px;
    }

    .snap-section :global(.picture) {
      min-height: calc(100svh - var(--crew-title-height) - 24px);
      min-height: calc(100vh - var(--crew-title-height) - 24px);
      min-height: calc(100dvh - var(--crew-title-height) - 24px);
      scroll-snap-align: center;
      scroll-snap-stop: always;
      width: 100%;
      aspect-ratio: auto;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      margin-top: 0;
      margin-bottom: 0;
      padding: 0;
    }

    .snap-section :global(.picture img) {
      width: min(84vw, clamp(220px, 64vw, 380px));
      height: auto;
    }
  }

  @media (min-width: 485px) and (max-width: 870px) {
    .snap-section :global(.picture img) {
      width: min(72vw, clamp(180px, 52vw, 300px));
      margin-top: 100px;
    }
  }

  @media (max-width: 400px) {
    .snap-section :global(.picture img) {
      width: 100vw;
      max-width: 100vw;
      margin-top: 50px
    }
  }

  @media (max-width: 400px) and (max-height: 700px) {
    .snap-section :global(.picture img) {
      margin-top: 50px;
      width: 90%
    }
  }

  @media (max-height: 800px) {
    .snap-section :global(.picture img) {
      height: auto;
    }
  }

  @media (max-height: 800px) and (max-width: 870px) {
    .snap-section {
      gap: 0px;
    }
  }

  @media (min-height: 1080px) and (min-width: 1200px) {
    .body {
      width: min(1200px, 96vw);
      max-width: none;
    }

    .snap-section {
      gap: 15vh;
      grid-template-columns: repeat(2, minmax(380px, 1fr));
    }
  }
  li {
    font-family: "Courier New", monospace;
  }

</style>


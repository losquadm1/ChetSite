---
import Layout from "@layouts/Layout.astro";
import SampleComponent from "@components/SampleComponent.astro";
import Container from "@components/Container.astro";
import AstroLogo from "@assets/images/astro-logo-light-gradient.png";
import { Content as SampleMarkdown } from "@content/sample-markdown.md";
import { Image } from "astro:assets";
import Header from "@components/Header.astro";
import HeaderMobile from "@components/HeaderMobile.astro";
import Story from "@components/Story.astro";
---

<Layout title="Crew Stories">

  <Header/>
  <HeaderMobile/>

  <Container>
<div class="JoContain">
    <div class="JoBlog">
        <div class="JoBlogIntro">
    <img src="/images/geogif.gif"/>
            <div class="JoBlogInner">
        <h1><img src="/images/jobloglogo.webp" alt="Crew Stories'"/></h1>
        <h2>Crew Stories!</h2>
        </div>
    <img src="/images/geogif.gif"/>
</div>
    
    <div class="buttons">
                <h3><button class="blogbutton"><a href="/jos-blog"><img src="/images/johome.webp" alt="Home"/></a></button></h3>
                <h3><button class="blogbutton"><a href="/jos-blog/coolwallpapers"><img src="/images/coolwallpapers.gif" alt="Cool Wallpapers"/></a></button></h3>
                </div>


    <Story name="Krystal McAdams" role="Social Media Manager / Production Assistant" title="Where We’re Meant to Be" story="I joined the Chet crew around the beginning of Chet Goes to a Party as a Production Assistant, adding the Social Media Manager title in the beginning of Chet Falls in Love. I remember Mike, particularly, being hesitant on me co-running the account, and rightfully so! Experience aside, I was handling Tasty Pictures’ baby. That’s a scary thing to hand off to someone. That’s why it was such an honor when I got the thumbs up. I was behind the camera in a lot of the photos you see on Instagram and when I accidentally expressed this fact, Mike and Candice were like “pause,” and got me some, on camera, pictures with the puppet, the myth, the legend, Chet. Having gone from a Production Assistant to, not only a friend, but a trusted colleague, means the world to me. And I can speak for everyone involved when I say this production when I say this is where we were meant to be, on set riffing off each other, on and off camera." picture="/images/story/Krystal McAdams.jpeg" alt="Krystal McAdams posing with Chet, they are smiling, holding a slate while Chet is grinning at knee height." />
    <Story name="Tim Borland" role="Production Assistant" title="Late Night (and early morning) Shoot"story="During the shooting of Chet 2, I was helping out with a scene, and as with many Chet shoots this one went particularly longer then planned. As the night went on and was about 1 am, I figured that we were almost done that night. I was very naïve in thinking so. Staying up till 5 am seeing the sun start to rise again as I watch behind the camera seeing Chet laying on the ground with like 5 lights surrounding him, everyone including myself in an almost delirious state, made me realize how dedicated everyone was to seeing this blue puppet story be told." picture="/images/story/Tim Borland.jpeg" alt="Chet laying on the ground, nobody else around. He must be tired from thhe late night shoot"/>
</div>
</div> 
</Container>

<style>
    .buttons{
        display: flex;
        flex-wrap: wrap;
        flex-direction: row;
        justify-content: center;
        gap: 20px;
        margin-top: 20px;
        }
    .buttons button{
        border: 5px outset #d5d5d5;
        background-color: #d5d5d5;
        width:300px;
        height:70px;
        padding: 0px;
    }
    .buttons button a{
        display: block;
        width: 100%;
        height: 100%;
    }
    .buttons button img{
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .buttons button img[src="/images/johome.webp"]{
        object-fit: contain;
        padding: 0;
        transform: scale(1.3);
        margin-top: 2px;
    }
    .buttons button img[src="/images/coolwallpapers.gif"]{
        object-fit: contain;
        transform: none;
    }
     .buttons button:hover{
         -webkit-filter: brightness(60%);
}
    body{
        background-image: url("/images/JoStar.webp");
        background-repeat: repeat;
        background-color: rgb(40, 0, 53);
    }

    .JoContain{
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: rgb(0, 0, 0, .2);
        margin-top: 60px;}

    .JoBlog{
        display: flex;
        flex-direction: Column;
        align-items: center;
        justify-content:center;
        padding: 20px;
        border: 15px solid #ff00b4;
        border-style: ridge;
        width: 100%;
    }

    .JoBlogIntro{
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content:center;
    }

    .JoBlogInner{
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .JoBlogInner img{
        max-width:400px;
    }

    .JoBlog img[src="/images/geogif.gif"]{
        margin-right: -40px;
        margin-top: -100px;
        padding: 50px;
    }
    @media (max-width: 900px) {
        .JoBlog img[src="/images/geogif.gif"]{
        display: none
    }
}
 @media (max-width: 460px) {
        .JoBlog img{
        width: 100%;
    } }

    h1, h2, h3, p{
        color: #ffade6;
        font-family: "Comic Sans MS", sans-serif;}
</style>
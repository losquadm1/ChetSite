---
const { title, subtitle = "The Creators" } = Astro.props;
---

<div class="title-wrap">
    <h1>{title}</h1>
    <h2 id="crew-sticky-subtitle">{subtitle}</h2>
    <div class="pad"><p> </p></div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const subtitleEl = document.getElementById("crew-sticky-subtitle");
        const panels = document.querySelectorAll("[data-sticky-subtitle]");
        const scrollRoot = document.querySelector(".page-snap");

        if (!subtitleEl || !panels.length) return;

        let debounceTimer: ReturnType<typeof setTimeout> | null = null;

        const setSubtitle = (panel: Element) => {
            const next = panel.getAttribute("data-sticky-subtitle");
            if (!next || next === subtitleEl.textContent) return;
            subtitleEl.style.opacity = "0";
            setTimeout(() => {
                subtitleEl.textContent = next;
                subtitleEl.style.opacity = "1";
            }, 150);
        };

        setSubtitle(panels[0]);

        const observer = new IntersectionObserver(
            (entries) => {
                const visible = entries
                    .filter((entry) => entry.isIntersecting)
                    .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

                if (visible) {
                    if (debounceTimer) clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(() => setSubtitle(visible.target), 1);
                }
            },
            {
                root: scrollRoot || null,
                threshold: [0.4, 0.6, 0.8],
            }
        );

        panels.forEach((panel) => observer.observe(panel));
    });
</script>

<style>
    .title-wrap {
        position: absolute;
        place-self: center;
        top: 0;
        z-index: 20;
        background-color: transparent;
        text-align: center;
        width: 100vw;
    }

    h1{
        padding-top: 40px;
        margin-bottom: 6px;
    }

    h2 {
        margin: 0;
        font-weight: normal;
        padding-bottom: 10px;
        padding-top: 5px;
        margin-top: -25px;
        font-family: "Courier New", monospace;
        font-size: 40px;
        opacity: 1;
        transition: opacity 0.15s ease;
    }

    @media (max-width: 700px) {
        .title-wrap {
            top: 0;
            padding-top: 50px;
            box-sizing: border-box;
        }

        h1 {
            display: none;
            padding-bottom: 0;
        }

        h2 {
            display: block;
            margin-top: 10px;
            padding-top: 0px;
            font-size: 30px;
        }

        .pad {
            height: 0px; /* Adjust this value as needed to create space for the mobile header */
        }

        
    }
</style>